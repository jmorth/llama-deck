# Optional: override defaults here
# Copy this file to .env and edit as needed.

# Port for the web UI
MANAGER_PORT=8080

# Path to llama-server binary on the host (for mounting into container)
# LLAMA_SERVER_PATH=/usr/local/bin/llama-server

# Model directory on the host (mounted into container)
MODELS_DIR=/home/user/models

# Port range for llama-server instances
PORT_RANGE_START=8081
PORT_RANGE_END=9000
